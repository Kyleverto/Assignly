# Copy this file to .env.local and fill in the values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace_with_a_random_32plus_char_string
BETTER_AUTH_URL=http://localhost:3000

# Database (from Neon dashboard)
DATABASE_URL=postgres://...

# Token encryption — run: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=replace_with_64_hex_chars

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Feature flags
MAX_AGENT_ITERATIONS=8

# Demo mode — password for the shared demo@assignly.demo account
# Set any value you like; it never leaves the server
DEMO_USER_PASSWORD=replace_with_any_secret_string

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
# Add a second redirect URI for your Vercel URL when you deploy
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
